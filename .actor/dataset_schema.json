{
    "$schema": "https://apify.com/schemas/v1/dataset.ide.json",
    "actorSpecification": 1,
    "fields": {
        "sku": { "type": "string", "title": "SKU" },
        "name": { "type": "string", "title": "Product Name" },
        "price": { "type": "integer", "title": "Price (MXN)" },
        "currency": { "type": "string", "title": "Currency" },
        "departmentId": { "type": "string", "title": "Department ID" },
        "department": { "type": "string", "title": "Department" },
        "subdepartmentId": { "type": "string", "title": "Subdepartment ID" },
        "subdepartment": { "type": "string", "title": "Subdepartment" },
        "description": { "type": "string", "title": "Description" },
        "application": { "type": "string", "title": "Application Instructions" },
        "ingredients": { "type": "string", "title": "Ingredients" },
        "olfactiveFamily": { "type": "string", "title": "Olfactive Family" },
        "imageUrls": { "type": "array", "title": "Image URLs", "items": { "type": "string" } },
        "hasCarousel": { "type": "boolean", "title": "Has Image Carousel" },
        "variantClass": { "type": "string", "title": "Variant Class" },
        "url": { "type": "string", "title": "Product URL" }
    },
    "views": {
        "overview": {
            "title": "Overview",
            "transformation": {
                "fields": [
                    "sku",
                    "name",
                    "department",
                    "subdepartment",
                    "price",
                    "currency",
                    "hasCarousel",
                    "url"
                ]
            },
            "display": {
                "component": "table",
                "properties": {
                    "sku": {
                        "label": "SKU",
                        "format": "text"
                    },
                    "name": {
                        "label": "Name",
                        "format": "text"
                    },
                    "department": {
                        "label": "Department",
                        "format": "text"
                    },
                    "subdepartment": {
                        "label": "Subdepartment",
                        "format": "text"
                    },
                    "price": {
                        "label": "Price",
                        "format": "number"
                    },
                    "currency": {
                        "label": "Currency",
                        "format": "text"
                    },
                    "hasCarousel": {
                        "label": "Carousel",
                        "format": "boolean"
                    },
                    "url": {
                        "label": "URL",
                        "format": "link"
                    }
                }
            }
        }
    }
}